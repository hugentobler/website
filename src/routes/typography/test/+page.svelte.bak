<!-- NOT USED - TODO: Delete or refactor later

<script lang="ts">
	import { Popover } from "bits-ui";
	import { getContext } from "svelte";
	import { Slider, ToggleGroup } from "$lib/components/ui";
	import type { TypographyConfig, UniStretch } from "$lib/typography/config";
	import { trackingDefs } from "$lib/typography/config";

	// === Global ===
	let font = $state<"UNI" | "BM">("UNI");
	let gridOn = $state<boolean>(true);
	let gridClass = $derived(gridOn ? "baseline-grid-major" : "");
	let rhythm = $state<number>(6);

	// === UNI: Size & Leading ===
	let uniSize = $state<number>(16);
	let uniUnits = $state<number>(4);
	let uniLeading = $derived(rhythm * uniUnits);

	// === UNI: Stretch ===
	import { UNI_STRETCH, UNI_STRETCH_WEIGHTS, UNI_WEIGHTS } from "$lib/typography/config";

	let uniStretchIdx = $state<number>(2);
	let uniStretch = $derived(UNI_STRETCH[uniStretchIdx] as UniStretch);
	const currentUniWeights = $derived<readonly number[]>(UNI_STRETCH_WEIGHTS[uniStretch]);

	// === UNI: Weights ===
	const allUniWeights = $derived<readonly number[]>(UNI_WEIGHTS);
	let uniWeight = $state<number>(400);

	let uniTrackingIdx = $state<number>(2);
	let uniItalic = $state<boolean>(false);

	// === Berkeley: Size & Leading ===
	let bmSize = $state<number>(16);
	let bmUnits = $state<number>(4);
	let bmLeading = $derived(rhythm * bmUnits);

	// === Berkeley: Axes ===
	let bmWght = $state<number>(400);
	let bmWdth = $state<number>(100);
	let bmSlnt = $state<number>(0);
	let bmTrackingIdx = $state<number>(2);

	// Create a route-level <div> for applying vars to
	let container = $state<HTMLDivElement>();

	$effect(() => {
		const r = container;
		if (!r) return;

		// map tracking indices to em values
		const sansTrackingEm = `${trackingDefs[Math.min(uniTrackingIdx, trackingDefs.length - 1)].em}em`;
		const monoTrackingEm = `${trackingDefs[Math.min(bmTrackingIdx, trackingDefs.length - 1)].em}em`;

		// axes
		r.style.setProperty("--sans-weight", `${uniWeight}`);
		r.style.setProperty("--sans-stretch", `${uniStretch}`);
		r.style.setProperty("--sans-style", uniItalic ? "italic" : "normal");
		r.style.setProperty("--sans-tracking", sansTrackingEm);

		r.style.setProperty("--mono-wght", `${bmWght}`);
		r.style.setProperty("--mono-stretch", `${bmWdth}%`);
		r.style.setProperty("--mono-slnt", `${bmSlnt}`);
		r.style.setProperty("--mono-tracking", monoTrackingEm);

		// base sizes/leading
		r.style.setProperty("--sans-text-base", `${uniSize}px`);
		r.style.setProperty("--sans-leading-base-units", `${uniUnits}`);
		r.style.setProperty("--mono-text-base", `${bmSize}px`);
		r.style.setProperty("--mono-leading-base-units", `${bmUnits}`);

		r.style.setProperty("--type-rhythm", `${rhythm}px`);
	});

	// Retrieve the route typography context
	type TypographyCtx = {
		get: () => TypographyConfig;
		set: (next: TypographyConfig) => void;
		apply: () => void;
	};
	const typCtx = getContext<TypographyCtx>("typographyConfig");

	// Live apply: whenever local state changes, push into route config
	$effect(() => {
		if (!typCtx) return;
		const next: TypographyConfig = {
			rhythm,
			uni: {
				size: uniSize,
				units: uniUnits,
				faces: {
					"ultra-condensed": { weight: 400 },
					condensed: { weight: 400 },
					normal: { weight: uniWeight },
					expanded: { weight: 400 },
				},
				stretch: uniStretch as UniStretch,
				italic: uniItalic,
				trackingIdx: uniTrackingIdx,
			},
			berkeley: {
				size: bmSize,
				units: bmUnits,
				wght: bmWght,
				wdth: bmWdth,
				slnt: bmSlnt,
				trackingIdx: bmTrackingIdx,
			},
		};
		typCtx.set(next);
		typCtx.apply();
	});

	function applyToRoute() {
		if (!typCtx) return;
		const next: TypographyConfig = {
			rhythm,
			uni: {
				size: uniSize,
				units: uniUnits,
				faces: {
					"ultra-condensed": { weight: 400 },
					condensed: { weight: 400 },
					normal: { weight: 400 },
					expanded: { weight: 400 },
				},
				stretch: uniStretch as UniStretch,
				italic: uniItalic,
				trackingIdx: uniTrackingIdx,
			},
			berkeley: {
				size: bmSize,
				units: bmUnits,
				wght: bmWght,
				wdth: bmWdth,
				slnt: bmSlnt,
				trackingIdx: bmTrackingIdx,
			},
		};
		typCtx.set(next);
		typCtx.apply();
	}
</script>

{#snippet stepper({
	label,
	value,
	setValue,
	suffix = "",
	prev = value - 1,
	next = value + 1,
	display = undefined,
}: {
	label: string;
	value: number;
	setValue: (v: number) => void;
	suffix?: string;
	prev?: number;
	next?: number;
	display?: string;
})}
	<label class="flex items-center gap-3">
		<span class="type-sans-sm">{label}</span>
		<div
			class="h-input rounded-card-sm border-border bg-background-alt shadow-mini flex items-center gap-x-0.5 border px-[4px] py-1"
		>
			<button
				aria-label={`decrease ${label}`}
				onclick={() => setValue(prev)}
				class="rounded-9px bg-background-alt hover:bg-muted active:bg-dark-10 data-[state=on]:bg-muted data-[state=off]:text-foreground-alt data-[state=on]:text-foreground active:data-[state=on]:bg-dark-10 inline-flex h-10 items-center justify-center px-3 text-sm transition-all active:scale-[0.98]"
			>
				−
			</button>
			<span
				class="rounded-9px bg-background-alt inline-flex h-10 items-center justify-center px-3 text-sm"
			>
				{display ?? `${value}${suffix}`}
			</span>
			<button
				aria-label={`increase ${label}`}
				onclick={() => setValue(next)}
				class="rounded-9px bg-background-alt hover:bg-muted active:bg-dark-10 data-[state=on]:bg-muted data-[state=off]:text-foreground-alt data-[state=on]:text-foreground active:data-[state=on]:bg-dark-10 inline-flex h-10 items-center justify-center px-3 text-sm transition-all active:scale-[0.98]"
			>
				+
			</button>
		</div>
	</label>
{/snippet}

{#snippet slider({
	value,
	setValue,
	availableValues,
	steps,
	formatLabel,
	formatThumbLabel,
	disabled = false,
}: {
	value: number;
	setValue: (v: number) => void;
	availableValues: readonly number[];
	steps?: number;
	formatLabel?: (v: number) => string | undefined;
	formatThumbLabel?: (v: number) => string | undefined;
	disabled?: boolean;
})}
	{@const min = Math.min(...availableValues)}
	{@const max = Math.max(...availableValues)}
	{@const step = 1}
	<div class="flex h-60 justify-center">
		<Slider.Root
			type="single"
			orientation="vertical"
			value={[value]}
			{min}
			{max}
			step={steps ?? step}
			class="relative flex h-full touch-none flex-col items-center select-none"
			trackPadding={3}
			onValueChange={(value) => setValue(value)}
			{disabled}
		>
			{#snippet children({ tickItems })}
				<span
					class="relative h-full w-2 cursor-pointer overflow-hidden rounded-full bg-(--background)"
				>
					<Slider.Range class="absolute w-full bg-(--foreground)" />
				</span>
				<Slider.Thumb
					index={0}
					class="border-border-input hover:border-dark-40 focus-visible:ring-foreground dark:bg-foreground dark:shadow-card data-active:border-dark-40 z-5 block size-[25px] cursor-pointer rounded-full border bg-(--background) shadow-sm transition-colors focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-hidden disabled:pointer-events-none disabled:opacity-50 data-active:scale-[0.98]"
				/>
				{#if formatThumbLabel}
					<Slider.ThumbLabel
						index={0}
						class="text-muted-foreground ml-5 text-sm font-medium leading-none"
						position="right"
					>
						{formatThumbLabel(value)}
					</Slider.ThumbLabel>
				{/if}
				{#each tickItems as { value: tickValue, index }}
					{@const tickText = formatLabel?.(tickValue)}
					{#if tickText !== undefined}
						<Slider.TickLabel
							{index}
							class="text-muted-foreground data-bounded:text-foreground ml-5 text-sm leading-none font-medium"
							position="right"
						>
							{tickText}
						</Slider.TickLabel>
					{/if}
					<Slider.Tick {index} class="bg-background-alt data-bounded:bg-dark-40 size-2" />
				{/each}
			{/snippet}
		</Slider.Root>
	</div>
{/snippet}

<div bind:this={container} class={gridClass}>
	<section class="space-y-6 p-6">
		<div class="fixed right-6 bottom-6 z-50">
			<Popover.Root open>
				<Popover.Trigger class="type-sans-sm cursor-pointer underline">Settings</Popover.Trigger>
				<Popover.Content side="top" class="max-h-[80vh] overflow-y-auto bg-white p-6">
					<div class="grid grid-cols-[auto_1fr] items-start gap-6">
						<div class="grid content-start gap-4">
							<label class="flex items-center gap-3">
								<span class="type-sans-sm">Font</span>
								<div
									class="h-input rounded-card-sm border-border bg-background-alt shadow-mini flex items-center gap-x-0.5 border px-[4px] py-1"
								>
									<button
										aria-label="Univers"
										value="UNI"
										data-state={font === "UNI" ? "on" : "off"}
										onclick={() => (font = "UNI")}
										class="rounded-9px bg-background-alt hover:bg-muted active:bg-dark-10 data-[state=on]:bg-muted data-[state=off]:text-foreground-alt data-[state=on]:text-foreground active:data-[state=on]:bg-dark-10 inline-flex h-10 items-center justify-center px-3 text-sm transition-all active:scale-[0.98]"
										>Univers</button
									>
									<button
										aria-label="Berkeley Mono"
										value="BM"
										data-state={font === "BM" ? "on" : "off"}
										onclick={() => (font = "BM")}
										class="rounded-9px bg-background-alt hover:bg-muted active:bg-dark-10 data-[state=on]:bg-muted data-[state=off]:text-foreground-alt data-[state=on]:text-foreground active:data-[state=on]:bg-dark-10 inline-flex h-10 items-center justify-center px-3 text-sm transition-all active:scale-[0.98]"
										>Berkeley Mono</button
									>
									<div class="grid gap-3">
										<button
											class="rounded-9px bg-muted text-foreground inline-flex h-10 items-center justify-center px-3 text-sm"
											onclick={applyToRoute}
										>
											Apply to route
										</button>
									</div>
								</div>
							</label>

							{@render stepper({
								label: "Rhythm",
								value: rhythm,
								setValue: (v) => (rhythm = v),
								suffix: "px",
								prev: rhythm - 1,
								next: rhythm + 1,
							})}

							{#if font === "UNI"}
								{@render stepper({
									label: "Size",
									value: uniSize,
									setValue: (v) => (uniSize = v),
									suffix: "px",
									prev: uniSize - 1,
									next: uniSize + 1,
								})}
								{@render stepper({
									label: "Leading",
									value: uniUnits,
									setValue: (v) => (uniUnits = v),
									suffix: "u",
									prev: uniUnits - 1,
									next: uniUnits + 1,
									display: `${uniLeading}px`,
								})}
								<label class="flex items-center gap-3">
									<span class="type-sans-sm">Italic</span>
									<input type="checkbox" bind:checked={uniItalic} class="size-4" />
								</label>
							{:else}
								{@render stepper({
									label: "Size",
									value: bmSize,
									setValue: (v) => (bmSize = v),
									suffix: "px",
									prev: bmSize - 1,
									next: bmSize + 1,
								})}
								{@render stepper({
									label: "Leading",
									value: bmUnits,
									setValue: (v) => (bmUnits = v),
									suffix: "u",
									prev: bmUnits - 1,
									next: bmUnits + 1,
									display: `${bmLeading}px`,
								})}
							{/if}

							<label class="flex items-center gap-3">
								<span class="type-sans-sm">Grid</span>
								<input type="checkbox" bind:checked={gridOn} class="size-4" />
							</label>
						</div>

						<div class="grid grid-cols-4 items-start gap-6">
							<div class="[grid-row:1/-1] min-w-[180px]">
								<div class="type-sans-sm text-muted-foreground mb-1">Weight</div>
								<div class="grid grid-cols-[auto_1fr] items-center gap-3">
									{@render slider({
										value: font === "UNI" ? uniWeight : bmWght,
										setValue: (v) => (font === "UNI" ? (uniWeight = v) : (bmWght = v)),
										availableValues:
											font === "UNI" ? (currentUniWeights as number[]) : ([100, 900] as const),
										steps: font === "UNI" ? 100 : 50,
										formatLabel: (v) => {
											const available = font === "UNI" ? currentUniWeights : [100, 900];
											return available.includes(v) ? `${v}` : undefined;
										},
										formatThumbLabel: (v) => `${v}`,
									})}
								</div>
							</div>
							<div class="[grid-row:1/-1] min-w-[180px]">
								<div class="type-sans-sm text-muted-foreground mb-1">
									{font === "UNI" ? "Stretch" : "Width"}
								</div>
								<div class="grid grid-cols-[auto_1fr] items-center gap-3">
									{@render slider({
										value: font === "UNI" ? uniStretchIdx : bmWdth,
										setValue: (v) => (font === "UNI" ? (uniStretchIdx = v) : (bmWdth = v)),
										availableValues:
											font === "UNI"
												? Array.from({ length: UNI_STRETCH.length }, (_, i) => i)
												: ([60, 100] as const),
										steps: font === "UNI" ? undefined : 1,
										formatLabel:
											font === "UNI"
												? (i) => UNI_STRETCH[i]
												: (v) => (v % 10 === 0 ? `${v}%` : undefined),
									})}
								</div>
							</div>
							<div class="[grid-row:1/-1] min-w-[180px]">
								<div class="type-sans-sm text-muted-foreground mb-1">Slant</div>
								<div class="grid grid-cols-[auto_1fr] items-center gap-3">
									{@render slider({
										value: bmSlnt,
										setValue: (v) => (bmSlnt = v),
										availableValues: [-16, 0] as const,
										steps: 1,
										formatLabel: (v) => (v % 4 === 0 ? `${v}°` : undefined),
										formatThumbLabel: (v) => `${v}°`,
										disabled: font !== "BM",
									})}
								</div>
							</div>
							<div class="[grid-row:1/-1] min-w-[180px]">
								<div class="type-sans-sm text-muted-foreground mb-1">Tracking</div>
								<div class="grid grid-cols-[auto_1fr] items-center gap-3">
									{@render slider({
										value: font === "UNI" ? uniTrackingIdx : bmTrackingIdx,
										setValue: (v) => (font === "UNI" ? (uniTrackingIdx = v) : (bmTrackingIdx = v)),
										availableValues: trackingDefs.map((_, i) => i),
										formatLabel: (i) => trackingDefs[i]?.name,
										formatThumbLabel: (i) => trackingDefs[i]?.name,
									})}
								</div>
							</div>
						</div>
					</div>
				</Popover.Content>
			</Popover.Root>
		</div>

		<header>
			{#if font === "UNI"}
				<h1 class={`uni-type-lg uni-axes font-sans`}>Body Text Test Preview</h1>
				<p class={`uni-type-sm uni-axes font-sans`}>
					Focused test page for vertical sliders and rhythm.
				</p>
			{:else}
				<h1 class="bm-type-lg bm-axes font-mono">Body Text Test Preview</h1>
				<p class="bm-type-sm bm-axes font-mono">Focused test page for vertical sliders and rhythm.</p>
			{/if}
		</header>

		{#if font === "UNI"}
			<article class="space-y-4">
				<p
					class={`uni-type-base uni-axes font-sans ${gridClass}`}
					style={`--leading-units: ${uniUnits}`}
				>
					Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut
					labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco
					laboris nisi ut aliquip ex ea commodo consequat.
				</p>
				<p
					class={`uni-type-base uni-axes font-sans ${gridClass}`}
					style={`--leading-units: ${uniUnits}; margin-top: calc(var(--type-rhythm) * 2)`}
				>
					Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla
					pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt
					mollit anim id est laborum.
				</p>
			</article>
		{:else}
			<article class="space-y-4">
				<p
					class={`bm-type-base bm-axes font-mono ${gridClass}`}
					style={`--leading-units: ${bmUnits}`}
				>
					Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut
					labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco
					laboris nisi ut aliquip ex ea commodo consequat.
				</p>
				<p
					class={`bm-type-base bm-axes font-mono ${gridClass}`}
					style={`--leading-units: ${bmUnits}; margin-top: calc(var(--type-rhythm) * 2)`}
				>
					Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla
					pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt
					mollit anim id est laborum.
				</p>
			</article>
		{/if}
	</section>
</div>

-->
