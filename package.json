{
  "name": "hvgentobler.com",
  "version": "1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "biome format",
    "lint": "biome check",
    "pages:dev": "wrangler pages dev -- bun run dev",
    "pages:deploy": "bun run build && wrangler pages deploy .svelte-kit/cloudflare",
    "fonts:deploy": "node upload_fonts.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@sveltejs/adapter-cloudflare": "^7.2.3",
    "@sveltejs/enhanced-img": "^0.8.2",
    "@sveltejs/kit": "^2.43.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.5.2",
    "dotenv": "^17.2.2",
    "markdoc-svelte": "^3.0.0",
    "svelte": "^5.39.6",
    "svelte-check": "^4.3.2",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "wrangler": "^4.40.0"
  },
  "dependencies": {
    "dayjs": "^1.11.18",
    "yaml": "^2.8.1"
  }
}
