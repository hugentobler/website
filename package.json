{
	"name": "hvgentobler.com",
	"version": "1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "biome format",
		"lint": "biome check",
		"pages:dev": "wrangler pages dev -- bun run dev",
		"pages:deploy": "bun run build && wrangler pages deploy .svelte-kit/cloudflare",
		"fonts:deploy": "node upload_fonts.js"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@sveltejs/adapter-cloudflare": "^7.2.4",
		"@sveltejs/enhanced-img": "^0.9.2",
		"@sveltejs/kit": "^2.49.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^25.0.3",
		"dotenv": "^17.2.3",
		"markdoc-svelte": "^3.0.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.46.1",
		"svelte-check": "^4.3.5",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-svelte-plugin": "^0.3.50",
		"vite": "^7.3.0",
		"wrangler": "^4.45.2"
	},
	"dependencies": {
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.18",
		"tailwind-merge": "^3.4.0",
		"yaml": "^2.8.2"
	}
}
